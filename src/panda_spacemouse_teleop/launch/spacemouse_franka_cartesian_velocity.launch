<launch>
  <!--
    Helper launch for ROS1 Franka setups:
    - loads/starts cartesian_velocity_example_controller
    - starts SpaceMouse teleop and remaps to the controller command topic

    Assumes franka_control.launch is already running.
  -->

  <arg name="config" default="$(find panda_spacemouse_teleop)/config/teleop.yaml"/>

  <rosparam param="/cartesian_velocity_example_controller/type">franka_example_controllers/CartesianVelocityExampleController</rosparam>
  <rosparam param="/cartesian_velocity_example_controller/arm_id">panda</rosparam>
  <rosparam param="/cartesian_velocity_example_controller/joint_names">[panda_joint1, panda_joint2, panda_joint3, panda_joint4, panda_joint5, panda_joint6, panda_joint7]</rosparam>

  <node pkg="controller_manager"
        type="spawner"
        name="cartesian_velocity_example_controller_spawner"
        args="cartesian_velocity_example_controller"
        output="screen"/>

  <include file="$(find panda_spacemouse_teleop)/launch/spacemouse_teleop.launch">
    <arg name="config" value="$(arg config)"/>
    <arg name="twist_topic" value="/cartesian_velocity_example_controller/command"/>
  </include>
</launch>
